# AnimeTracker AI Agent 环境变量配置
# 复制此文件为 .env 并填入实际值

# DashScope API 密钥（必填）
DASHSCOPE_API_KEY=your-dashscope-api-key

# LLM 配置（默认使用 DashScope + qwen3.7-max）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-max
LLM_TEMPERATURE=0.7

# Spring Boot 后端 API 地址
BACKEND_API_BASE=http://localhost:8080

# Redis 配置（用于会话缓存）
REDIS_HOST=localhost
REDIS_PORT=6379

# 会话存储类型: redis / sqlite
SESSION_STORE=redis
