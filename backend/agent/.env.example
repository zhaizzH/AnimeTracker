# ---- DashScope LLM ----
DASHSCOPE_API_KEY=sk-your-key-here
LLM_MODEL=qwen3.7-max
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ---- Server ----
AGENT_HOST=0.0.0.0
AGENT_PORT=8090

# ---- Backend Spring Boot API ----
BACKEND_BASE_URL=http://localhost:8080/api/user

# ---- Database ----
DATABASE_URL=sqlite:///agent.db

# ---- Agent Runtime ----
AGENT_MAX_ITERATIONS=5
WS_HEARTBEAT_INTERVAL=30
