# ===================================================================
# AnimeTracker API — 本地开发环境配置
# 复制此文件为 application-local.yml 并填入实际值
# 启动时: --spring.profiles.active=local
# ===================================================================
spring:
  datasource:
    url: jdbc:mysql://localhost:3306/anime_tracker_dev?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
    username: root
    password: root

  data:
    redis:
      host: localhost
      port: 6379
      database: 1

  jackson:
    default-property-inclusion: non_null

mybatis-plus:
  configuration:
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

jwt:
  secret: dev-secret-key-not-for-production-use-change-it
  expiration: 86400000

logging:
  level:
    top.zhaizz.animetracker: DEBUG
